// ✅ v9 NEW: ДАНІ ДЛЯ ГРАФІКІВ ДАШБОРДУ "📊 Аналітика"
// Одна функція = один прохід по таблицях → один HTTP-запит на фронтенді
// ═══════════════════════════════════════════════════════════════
function getAnalyticsChartData() {
  const clients  = safeGetRangeValues(getSheet(SHEET_CLIENTS),  2, 1, null, 13).filter(r => r && r[0]);
  const subs     = safeGetRangeValues(getSheet(SHEET_SUBS),     2, 1, null, 16).filter(r => r && r[0]);
  const history  = safeGetRangeValues(getSheet(SHEET_HISTORY),  2, 1, null, 12).filter(r => r && r[0]);
  const bookings = safeGetRangeValues(getSheet(SHEET_BOOKINGS), 2, 1, null, 12).filter(r => r && r[0]);

  // 1) Динаміка доходу за 14 днів: послуги (Історія) + абонементи (продажі)
  const dayMap = {};
  const dayKeys = [];
  for (let i = 13; i >= 0; i--) {
    const d = new Date();
    d.setDate(d.getDate() - i);
    const key   = Utilities.formatDate(d, TZ, "dd.MM.yyyy");
    const label = Utilities.formatDate(d, TZ, "dd.MM");
    dayMap[key] = { label, services: 0, subs: 0 };
    dayKeys.push(key);
  }
  history.forEach(r => {
    const d = asDate(r[1]);
    if (!d) return;
    const key = fmtDate(d);
    if (dayMap[key]) dayMap[key].services += parseFloat(r[6]) || 0;
  });
  subs.forEach(r => {
    const d = asDate(r[6]);
    if (!d) return;
    const key = fmtDate(d);
    if (dayMap[key]) dayMap[key].subs += parseFloat(r[5]) || 0;
  });
  const revenueTrend = dayKeys.map(k => ({
    label: dayMap[k].label,
    services: fmt(dayMap[k].services),
    subs: fmt(dayMap[k].subs),
    total: fmt(dayMap[k].services + dayMap[k].subs)
  }));

  // 2) Топ послуг за кількістю (Історія + активні/виконані записи)
  const serviceCounts = {};
  history.forEach(r => {
    const key = String(r[5] || "—").split("|")[0].trim();
    if (key) serviceCounts[key] = (serviceCounts[key] || 0) + 1;
  });
  bookings.forEach(r => {
    const status = String(r[9] || "");
    if (!(status.includes("Виконано") || status.includes("Готово") || status.includes("Підтверджено") || status.includes("роботі"))) return;
    const key = String(r[8] || "—").split("|")[0].trim();
    if (key) serviceCounts[key] = (serviceCounts[key] || 0) + 1;
  });
  const topServices = Object.entries(serviceCounts)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 6)
    .map(([name, count]) => ({ name, count }));

  // 3) Статуси записів за останні 30 днів (для донат-діаграми)
  const monthAgo = new Date();
  monthAgo.setDate(monthAgo.getDate() - 30);
  const statusCounts = {};
  bookings.forEach(r => {
    const d = asDate(r[1]);
    if (d && d < monthAgo) return;
    let status = String(r[9] || "—").replace(/^[^\wА-Яа-яІіЇїЄєҐґ]+/u, "").trim() || "—";
    statusCounts[status] = (statusCounts[status] || 0) + 1;
  });
  const bookingStatuses = Object.entries(statusCounts).map(([name, count]) => ({ name, count }));

  // 4) Активні абонементи за типом
  const typeCounts = {};
  subs.forEach(r => {
    if (!isActiveStatus(r[10])) return;
    const t = String(r[4] || "—");
    typeCounts[t] = (typeCounts[t] || 0) + 1;
  });
  const subsByType = Object.entries(typeCounts).map(([name, count]) => ({ name, count }));

  // 5) Нові клієнти за 14 днів
  const clientDayMap = {};
  dayKeys.forEach(k => clientDayMap[k] = 0);
  clients.forEach(r => {
    const d = asDate(r[5]);
    if (!d) return;
    const key = fmtDate(d);
    if (clientDayMap[key] !== undefined) clientDayMap[key]++;
  });
  const newClientsTrend = dayKeys.map(k => ({ label: dayMap[k].label, count: clientDayMap[k] }));

  // 6) Завантаженість боксів (всі активні/виконані записи)
  const boxCounts = { "Box 1": 0, "Box 2": 0, "Box 3": 0 };
  bookings.forEach(r => {
    const status = String(r[9] || "");
    if (status.includes("Скасовано")) return;
    const box = String(r[4] || "").trim();
    if (boxCounts[box] !== undefined) boxCounts[box]++;
  });
  const boxLoad = Object.entries(boxCounts).map(([name, count]) => ({ name, count }));

  return { revenueTrend, topServices, bookingStatuses, subsByType, newClientsTrend, boxLoad };
}

