// ✅ v9.2 AUDIT (п.12): серверная валидация формата даты/времени
function isValidDateStr(s) {
  const m = String(s || "").trim().match(/^(\d{1,2})\.(\d{1,2})\.(\d{4})$/);
  if (!m) return false;
  const d = +m[1], mo = +m[2], y = +m[3];
  if (mo < 1 || mo > 12 || d < 1 || d > 31 || y < 2020 || y > 2100) return false;
  const dt = new Date(y, mo - 1, d);
  return dt.getFullYear() === y && dt.getMonth() === mo - 1 && dt.getDate() === d;
}
function isValidTimeStr(s) {
  const str = normalizeTime(s);
  const m = String(str).match(/^(\d{1,2}):(\d{2})$/);
  if (!m) return false;
  const h = +m[1], mi = +m[2];
  return h >= 0 && h <= 23 && mi >= 0 && mi <= 59;
}

function saveBooking(dateStr, timeStr, boxName, clientId, clientName, phone, service, source, note, actor, plateNumber) {
  return withScriptLock("saveBooking", function() {
    const sheet = getSheet(SHEET_BOOKINGS);
    if (!sheet) return false;
    if (!isValidDateStr(dateStr) || !isValidTimeStr(timeStr)) {
      Logger.log("❌ Невірний формат дати/часу: " + dateStr + " " + timeStr);
      return false;
    }
    if (isDateBlocked(dateStr)) {
      Logger.log("❌ Дата закрита для запису: " + dateStr);
      return false;
    }
    assertForeignKeys({ clientId });
    if (_isSlotTakenFresh(dateStr, timeStr, boxName)) {
      Logger.log("❌ Бокс вже зайнятий (fresh): " + boxName + " " + dateStr + " " + timeStr);
      return false;
    }
    const row = getNextRow(SHEET_BOOKINGS);
    const [day, month, year] = dateStr.split(".");
    const d = new Date(parseInt(year), parseInt(month) - 1, parseInt(day));
    const dayName = DAY_NAMES[d.getDay()];
    const normTime = normalizeTime(timeStr);
    const bookingId = genBookingId();
    sheet.getRange(row, 1, 1, 13).setValues([[
      bookingId, dateStr, dayName, normTime, boxName, clientId, clientName,
      normalizePhone(phone), service, "✅ Підтверджено", note || "",
      source || "Администратор",
      (plateNumber || "").toUpperCase().trim()
    ]]);
    invalidateBookingCache(dateStr);
    logAction(actor || source || "web", "Запись", "Booking", bookingId, "", "Підтверджено", dateStr);
    return bookingId;
  }, actor || source || "web");
}

function findBookingById(bookingId) {
  const sheet = getSheet(SHEET_BOOKINGS);
  if (!sheet) return null;
  const data = safeGetRangeValues(sheet, 2, 1, null, 12);
  if (!data || !data.length) return null;
