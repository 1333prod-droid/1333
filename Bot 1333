function blockDate(dateStr, actor) {
  return withScriptLock("blockDate", function () {
    const ds = String(dateStr || "").trim();
    if (!isValidDateStr(ds)) return { success: false, error: "bad_date" };
    const arr = getBlockedDates();
    if (arr.indexOf(ds) === -1) { arr.push(ds); _setBlockedDates(arr); }
    invalidateBookingCache(ds);
    logAction(actor || "CRM", "Блокування дати", "Schedule", ds, "", "Заблоковано", "");
    return { success: true, blocked: true, date: ds, blockedDates: arr };
  }, actor || "CRM");
}
function unblockDate(dateStr, actor) {
  return withScriptLock("unblockDate", function () {
    const ds = String(dateStr || "").trim();
    const arr = getBlockedDates();
    const i = arr.indexOf(ds);
    if (i !== -1) { arr.splice(i, 1); _setBlockedDates(arr); }
    invalidateBookingCache(ds);
    logAction(actor || "CRM", "Розблокування дати", "Schedule", ds, "", "Відкрито", "");
    return { success: true, blocked: false, date: ds, blockedDates: arr };
  }, actor || "CRM");
}
function toggleBlockDate(dateStr, actor) {
  return isDateBlocked(dateStr) ? unblockDate(dateStr, actor) : blockDate(dateStr, actor);
}

function asDate(value) {
  if (!value) return null;
  if (value instanceof Date) return value;
  if (typeof value === "number") {
    const dt = new Date((Math.floor(value) - 25569) * 86400 * 1000);
    return isNaN(dt.getTime()) ? null : dt;
  }
  const parts = String(value).trim().match(/^(\d{1,2})\.(\d{1,2})\.(\d{4})$/);
  if (!parts) return null;
  const dt = new Date(Number(parts[3]), Number(parts[2]) - 1, Number(parts[1]));
  return isNaN(dt.getTime()) ? null : dt;
}

function isPastDate(value) {
  const dt = asDate(value);
  if (!dt) return false;
  const today = new Date();
  const todayOnly = new Date(today.getFullYear(), today.getMonth(), today.getDate());
  const dateOnly = new Date(dt.getFullYear(), dt.getMonth(), dt.getDate());
  return dateOnly < todayOnly;
}

