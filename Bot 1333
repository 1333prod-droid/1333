function handleMarkVisit(chatId, userId, text, state) {
  if (state.step === 1) {
    const c = findClientById(text.trim());
    if (!c) { sendMessage(chatId, "❌ Клієнт не знайдений"); return; }
    const subs = getClientSubs(text.trim()).filter(s => String(s.status).includes("Активний") || String(s.status).includes("✅"));
    setState(userId, { action: "mark_visit", step: 2, clientId: text.trim(), clientName: c.name });
    const buttons = subs.map((s, i) => [{ text: (i+1) + ". " + s.typeName + " | 💰 " + fmt(s.balance) + " грн", callback_data: "visit_sub_" + text.trim() + "|" + s.subId }]);
    buttons.push([{ text: "💵 Готівка (без абонементу)", callback_data: "visit_cash_" + text.trim() }]);
    sendMessage(chatId, "👤 <b>" + c.name + "</b>\n💰 Загальний баланс: " + fmt(c.balance) + " грн\n\n🎫 <b>Оберіть абонемент або готівку:</b>", createInlineKeyboard(buttons));
  } else if (state.step === 2) {
    setState(userId, { ...state, step: 3, service: text });
    sendMessage(chatId, "💰 <b>Сума списання (грн):</b>");
  } else if (state.step === 3) {
    const cost = parseFloat(text) || 0;
    if (cost <= 0) { sendMessage(chatId, "❌ Введіть суму більше 0"); return; }
    setState(userId, { ...state, step: 4, cost });
    sendMessage(chatId, "📝 <b>Коментар</b> (або '-'):");
    } else if (state.step === 4) {
    try {
      let visit;
      if (state.subId) {
        visit = markVisit(state.clientId, state.subId, state.service, state.cost, text === "-" ? "" : text, "Telegram admin " + userId);
        if (!visit?.success) {
          sendMessage(chatId, "❌ Недостатньо коштів на абонементі!\nПеревірте баланс, або оберіть «💵 Готівка».");
          deleteState(userId);
          return;
        }
      } else {
        visit = markVisitCash(state.clientId, state.clientName, state.service, state.cost, text === "-" ? "" : text, "Telegram admin " + userId);
      }
      deleteState(userId);
      sendMessage(chatId,
        "✅ <b>Відвідування записано!</b>\n\n" +
        "👤 " + state.clientName + "\n" +
        "🔧 " + state.service + "\n" +
        (state.subId ? "💸 Списано: " + state.cost + " грн\n💰 Залишок на рахунку: " + fmt(visit.afterBalance) + " грн" : "💵 Оплачено готівкою: " + state.cost + " грн")
      );
      const clientData = findClientById(state.clientId);
      if (clientData?.telegramId && clientData.telegramId !== '0' && clientData.telegramId !== '') {
        sendMessage(clientData.telegramId,
          "🚗 <b>Відвідування зафіксовано!</b>\n\n" +
          "🔧 " + state.service + "\n" +
          (state.subId ? "💸 Списано: " + state.cost + " грн\n💰 Залишок: " + fmt(visit.afterBalance) + " грн" : "💵 Оплачено готівкою: " + state.cost + " грн")
        );
      }
      showAdminMenu(chatId);
    } catch(e) { sendMessage(chatId, "❌ Помилка: " + e); }
  }
}

