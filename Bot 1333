function activateSubscription(subId) {
  return withScriptLock("activateSubscription", function() {
    const sheet = getSheet(SHEET_SUBS);
    if (!sheet) return { success: false };
    const data = safeGetRangeValues(sheet, 2, 1, null, 16);
    if (!data || !data.length) return { success: false };
    for (let i = 0; i < data.length; i++) {
      if (!data[i] || String(data[i][1]).trim() !== String(subId).trim()) continue;
      const oldStatus = String(data[i][10] || "");
      const freezeDateStr = scriptProperties.getProperty("freeze_date_" + subId);
      let newEndDate = parseDate(data[i][7]);
      if (freezeDateStr) {
        const freezeDt = asDate(freezeDateStr);
        const today = new Date();
        if (freezeDt) {
          const todayOnly = new Date(today.getFullYear(), today.getMonth(), today.getDate());
          const freezeOnly = new Date(freezeDt.getFullYear(), freezeDt.getMonth(), freezeDt.getDate());
          const frozenDays = Math.max(0, Math.round((todayOnly - freezeOnly) / 86400000));
          if (frozenDays > 0) {
            const currentEnd = asDate(data[i][7]);
            if (currentEnd) {
              const extended = new Date(currentEnd);
              extended.setDate(extended.getDate() + frozenDays);
              newEndDate = fmtDate(extended);
              sheet.getRange(i + 2, 8).setValue(newEndDate);
            }
          }
        }
        scriptProperties.deleteProperty("freeze_date_" + subId);
      }
      sheet.getRange(i + 2, 11).setValue("✅ Активний");
      try { if (data[i][0]) { updateClientBalance(String(data[i][0])); updateClientMetrics(String(data[i][0])); } } catch(e) {}
      logAction("Telegram", "Розморозка абонемента", "Subscription", subId, oldStatus, "Активний", "new end: " + newEndDate);
      return { success: true, newEndDate };
    }
    return { success: false, error: "not found" };
  }, "Telegram");
}

