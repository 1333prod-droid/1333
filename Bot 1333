  const fc      = (r,c,rn,cn,color) => sheet.getRange(r,c,rn,cn).setFontColor(color);
  const bold    = (r,c,rn,cn) => sheet.getRange(r,c,rn,cn).setFontWeight('bold');
  const sz      = (r,c,rn,cn,n) => sheet.getRange(r,c,rn,cn).setFontSize(n);
  const align   = (r,c,rn,cn,h,v) => sheet.getRange(r,c,rn,cn).setHorizontalAlignment(h).setVerticalAlignment(v||'middle');
  const border  = (r,c,rn,cn,s) => sheet.getRange(r,c,rn,cn).setBorder(true,true,true,true,false,false,'#333333',SpreadsheetApp.BorderStyle[s||'SOLID']);
  const wrap    = (r,c,rn,cn) => sheet.getRange(r,c,rn,cn).setWrap(false);
  // ✅ fix: Range.setIndent не иснує в GAS API. Безпечний відступ через setIndentLevel.
  const indent  = (r,c,n) => { try { sheet.getRange(r,c).setIndentLevel(n||1); } catch (e) { /* відступ недоступний — пропускаємо */ } };

  // ── Ширина колонок ────────────────────────────────────────────
  sheet.setColumnWidth(1, 220);
  sheet.setColumnWidth(2, 150);
  sheet.setColumnWidth(3, 140);
  sheet.setColumnWidth(4, 30);
  sheet.setColumnWidth(5, 120);
  sheet.setColumnWidth(6, 90);
  sheet.setColumnWidth(7, 90);
  sheet.setColumnWidth(8, 90);

  // ── ЗАГОЛОВОК ─────────────────────────────────────────────────
  merge(1,1,1,8); setVal(1,1,"📊  1333 CAR CENTER — АНАЛІТИКА");
  bg(1,1,1,8,"#0a0a10"); fc(1,1,1,8,"#ffffff"); bold(1,1,1,8); sz(1,1,1,8,16);
  align(1,1,1,8,"center","middle"); sheet.setRowHeight(1,52);

  merge(2,1,1,6); setVal(2,1,"Оновлено: " + updated);
  bg(2,1,1,8,"#111118"); fc(2,1,1,8,"#888888"); sz(2,1,1,8,10);
  align(2,1,1,8,"center","middle"); sheet.setRowHeight(2,24);

  // ── РОЗДІЛ 1: KPI ─────────────────────────────────────────────
  const kpiMap = {};
  kpis.forEach(([k,v]) => kpiMap[k] = v);

  const kpiCards = [
    { label:"Клієнти",             val: kpiMap["Клієнти"]||0,           ico:"👥", color:"#1a1a2e", accent:"#a78bfa", fmt:"0"          },
    { label:"Активні абонементи",  val: kpiMap["Активні абонементи"]||0,ico:"💎", color:"#0d1a0d", accent:"#22c55e", fmt:"0"          },
    { label:"Продажі сьогодні",    val: kpiMap["Продажі сьогодні"]||0,  ico:"📆", color:"#1a1100", accent:"#eab308", fmt:'#,##0" ₴"' },
    { label:"Продажі місяця",      val: kpiMap["Продажі місяця"]||0,    ico:"📅", color:"#0d1726", accent:"#3b82f6", fmt:'#,##0" ₴"' },
    { label:"Загальний дохід",     val: kpiMap["Загальний дохід"]||0,   ico:"💰", color:"#1a0d1a", accent:"#f97316", fmt:'#,##0" ₴"' }
  ];

  // Верхній рядок KPI (рядки 4-7)
  sheet.setRowHeight(4,18); sheet.setRowHeight(5,36); sheet.setRowHeight(6,28); sheet.setRowHeight(7,18);

  kpiCards.forEach((kpi, i) => {
    const col = 1 + i + (i > 2 ? 1 : 0); // 1-based, пропускаємо розділову колонку після 3-ї
    // Для 5 KPI розміщуємо їх у колонках 1-5 (з урахуванням розділювача col 4 = empty)
    const c = i < 2 ? i + 1 : (i === 2 ? 3 : (i === 3 ? 5 : 7));
    if (i === 2) merge(4, 4, 4, 1); // розділова
    merge(4,c,4,1); bg(4,c,4,1, kpi.color); sheet.setRowHeight(4,18);
    merge(5,c,1,1); setVal(5,c, kpi.ico + "  " + kpi.val); bg(5,c,1,1, kpi.color);
    fc(5,c,1,1, kpi.accent); bold(5,c,1,1); sz(5,c,1,1,18); align(5,c,1,1,"center");
    sheet.getRange(5,c).setNumberFormat(kpi.fmt);
    merge(6,c,1,1); setVal(6,c, kpi.label); bg(6,c,1,1, kpi.color);
    fc(6,c,1,1,"#aaaaaa"); sz(6,c,1,1,9); align(6,c,1,1,"center"); bold(6,c,1,1);
    merge(7,c,1,1); bg(7,c,1,1, kpi.color);
  });

  // ── РОЗДІЛ 2: Середній чек + дохід по каналах ─────────────────
  const row2Start = 9;
  merge(row2Start, 1, 1, 8);
  setVal(row2Start, 1, "⚡  КЛЮЧОВІ МЕТРИКИ");
  bg(row2Start, 1, 1, 8, "#111118"); fc(row2Start, 1, 1, 8, "#a78bfa"); bold(row2Start, 1, 1, 8); sz(row2Start, 1, 1, 8, 11);
  align(row2Start, 1, 1, 8, "left"); sheet.setRowHeight(row2Start, 32);
  indent(row2Start, 1, 1);

  const metricRows = [
    ["Середній чек",       kpiMap["Середній чек"]||0,      '#,##0.00" ₴"', "#22c55e"],
    ["Дохід (послуги)",    kpiMap["Дохід (послуги)"]||0,   '#,##0" ₴"',    "#3b82f6"],
    ["Дохід (абонементи)", kpiMap["Дохід (абонементи)"]||0,'#,##0" ₴"',    "#a78bfa"],
    ["Популярна послуга",  kpiMap["Популярна послуга"]||"—","@",           "#eab308"]
  ];
  metricRows.forEach(([label, val, fmt, accent], idx) => {
    const r = row2Start + 1 + idx;
    sheet.setRowHeight(r, 26);
    setVal(r, 1, label); fc(r, 1, 1, 1, "#cccccc"); sz(r, 1, 1, 1, 11);
    setVal(r, 2, val); sheet.getRange(r, 2).setNumberFormat(fmt);
    fc(r, 2, 1, 1, accent); bold(r, 2, 1, 1); sz(r, 2, 1, 1, 12);
    bg(r, 1, 1, 8, idx % 2 === 0 ? "#111118" : "#0d0d14");
  });

  // ── РОЗДІЛ 3: Динаміка доходу (таблиця + спарклайни) ──────────
  const trend = charts.revenueTrend || [];
  const tStart = row2Start + metricRows.length + 3;

  merge(tStart, 1, 1, 8);
  setVal(tStart, 1, "📈  ДИНАМІКА ДОХОДУ · ОСТАННІ 14 ДНІВ");
  bg(tStart, 1, 1, 8, "#111118"); fc(tStart, 1, 1, 8, "#22c55e"); bold(tStart, 1, 1, 8); sz(tStart, 1, 1, 8, 11);
  align(tStart, 1, 1, 8, "left"); sheet.setRowHeight(tStart, 32);
  indent(tStart, 1, 1);

  // Шапка таблиці
  const thead = tStart + 1;
  ["Дата", "Послуги (₴)", "Абонементи (₴)", "Разом (₴)"].forEach((h, i) => {
    const c = [1,2,3,5][i];
    setVal(thead, c, h);
    bg(thead, c, 1, 1, "#1a1a2e"); fc(thead, c, 1, 1, "#888888"); bold(thead, c, 1, 1); sz(thead, c, 1, 1, 9);
    align(thead, c, 1, 1, i === 0 ? "left" : "right");
    sheet.setRowHeight(thead, 24);
  });

  // Дані таблиці
  trend.forEach((row, idx) => {
    const r = thead + 1 + idx;
    sheet.setRowHeight(r, 22);
    const isStripe = idx % 2 === 0;
    bg(r, 1, 1, 8, isStripe ? "#0a0a10" : "#0d0d14");
    setVal(r, 1, row.label); fc(r, 1, 1, 1, "#aaaaaa"); sz(r, 1, 1, 1, 10);
    setVal(r, 2, row.services||0); sheet.getRange(r,2).setNumberFormat('#,##0'); fc(r, 2, 1, 1, "#3b82f6"); sz(r,2,1,1,10); align(r,2,1,1,"right");
    setVal(r, 3, row.subs||0);     sheet.getRange(r,3).setNumberFormat('#,##0'); fc(r, 3, 1, 1, "#a78bfa"); sz(r,3,1,1,10); align(r,3,1,1,"right");
    setVal(r, 5, row.total||0);    sheet.getRange(r,5).setNumberFormat('#,##0'); fc(r, 5, 1, 1, "#22c55e"); bold(r,5,1,1); sz(r,5,1,1,10); align(r,5,1,1,"right");
  });
  // Підсумок
  const sumRow = thead + 1 + trend.length;
  sheet.setRowHeight(sumRow, 28);
  bg(sumRow, 1, 1, 8, "#111820");
  setVal(sumRow, 1, "РАЗОМ"); fc(sumRow, 1, 1, 1, "#ffffff"); bold(sumRow, 1, 1, 1); sz(sumRow, 1, 1, 1, 11);
  const totalSvc = trend.reduce((s,r)=>s+(r.services||0),0);
  const totalSub = trend.reduce((s,r)=>s+(r.subs||0),0);
  setVal(sumRow, 2, totalSvc); sheet.getRange(sumRow,2).setNumberFormat('#,##0'); fc(sumRow,2,1,1,"#3b82f6"); bold(sumRow,2,1,1); sz(sumRow,2,1,1,11); align(sumRow,2,1,1,"right");
  setVal(sumRow, 3, totalSub); sheet.getRange(sumRow,3).setNumberFormat('#,##0'); fc(sumRow,3,1,1,"#a78bfa"); bold(sumRow,3,1,1); sz(sumRow,3,1,1,11); align(sumRow,3,1,1,"right");
  setVal(sumRow, 5, totalSvc+totalSub); sheet.getRange(sumRow,5).setNumberFormat('#,##0'); fc(sumRow,5,1,1,"#22c55e"); bold(sumRow,5,1,1); sz(sumRow,5,1,1,13); align(sumRow,5,1,1,"right");

  // ── РОЗДІЛ 4: Топ послуг + Статуси записів (поряд) ───────────
  const s4start = sumRow + 3;
  const topSvcs = charts.topServices || [];
  const statuses = charts.bookingStatuses || [];
  const boxLoad  = charts.boxLoad || [];

  // Топ послуг (ліва колонка)
  merge(s4start, 1, 1, 3);
  setVal(s4start, 1, "🔧  ТОП ПОСЛУГ");
  bg(s4start, 1, 1, 3, "#111118"); fc(s4start, 1, 1, 3, "#f97316"); bold(s4start, 1, 1, 3); sz(s4start, 1, 1, 3, 11);
  align(s4start, 1, 1, 3, "left"); sheet.setRowHeight(s4start, 30);
  indent(s4start, 1, 1);

  topSvcs.slice(0,6).forEach((svc, idx) => {
    const r = s4start + 1 + idx;
    sheet.setRowHeight(r, 24);
    bg(r, 1, 1, 3, idx % 2 === 0 ? "#0a0a10" : "#0d0d14");
    setVal(r, 1, (idx+1) + ". " + svc.name); fc(r, 1, 1, 1, "#cccccc"); sz(r, 1, 1, 1, 10);
    setVal(r, 2, svc.count); fc(r, 2, 1, 1, "#f97316"); bold(r, 2, 1, 1); sz(r, 2, 1, 1, 11); align(r, 2, 1, 1, "right");
    setVal(r, 3, "разів"); fc(r, 3, 1, 1, "#666666"); sz(r, 3, 1, 1, 9);
  });

  // Статуси записів (права колонка)
  merge(s4start, 5, 1, 4);
  setVal(s4start, 5, "📋  СТАТУСИ ЗАПИСІВ (30 днів)");
  bg(s4start, 5, 1, 4, "#111118"); fc(s4start, 5, 1, 4, "#3b82f6"); bold(s4start, 5, 1, 4); sz(s4start, 5, 1, 4, 11);
  align(s4start, 5, 1, 4, "left"); indent(s4start, 5, 1);

  const statusEmoji = (name) => {
    if (String(name).includes("Виконано")||String(name).includes("Готово")) return "✅";
    if (String(name).includes("роботі")) return "🔶";
    if (String(name).includes("Підтверджено")) return "📌";
    if (String(name).includes("Скасовано")) return "❌";
    return "•";
  };
  statuses.slice(0,6).forEach((st, idx) => {
    const r = s4start + 1 + idx;
    sheet.setRowHeight(r, 24);
    bg(r, 5, 1, 4, idx % 2 === 0 ? "#0a0a10" : "#0d0d14");
    setVal(r, 5, statusEmoji(st.name) + " " + st.name); fc(r, 5, 1, 1, "#cccccc"); sz(r, 5, 1, 1, 10);
    setVal(r, 7, st.count); fc(r, 7, 1, 1, "#3b82f6"); bold(r, 7, 1, 1); sz(r, 7, 1, 1, 11); align(r, 7, 1, 1, "right");
    setVal(r, 8, "записів"); fc(r, 8, 1, 1, "#666666"); sz(r, 8, 1, 1, 9);
  });

  // ── РОЗДІЛ 5: Завантаженість боксів ──────────────────────────
  const s5start = s4start + Math.max(topSvcs.length, statuses.length) + 3;

  merge(s5start, 1, 1, 8);
  setVal(s5start, 1, "🏠  ЗАВАНТАЖЕНІСТЬ БОКСІВ");
  bg(s5start, 1, 1, 8, "#111118"); fc(s5start, 1, 1, 8, "#22c55e"); bold(s5start, 1, 1, 8); sz(s5start, 1, 1, 8, 11);
  align(s5start, 1, 1, 8, "left"); sheet.setRowHeight(s5start, 30);
  indent(s5start, 1, 1);

  const maxBoxCount = Math.max(1, ...boxLoad.map(b=>b.count));
  const barColors = ["#22c55e","#3b82f6","#f97316"];
  boxLoad.forEach((box, idx) => {
    const r = s5start + 1 + idx;
    sheet.setRowHeight(r, 28);
    bg(r, 1, 1, 8, idx % 2 === 0 ? "#0a0a10" : "#0d0d14");
    setVal(r, 1, box.name); fc(r, 1, 1, 1, "#ffffff"); bold(r, 1, 1, 1); sz(r, 1, 1, 1, 11);
    setVal(r, 2, box.count); sheet.getRange(r,2).setNumberFormat('0" записів"');
    fc(r, 2, 1, 1, barColors[idx % barColors.length]); bold(r, 2, 1, 1); sz(r, 2, 1, 1, 12);
    // Візуальний бар через символи
    const barLen = Math.round((box.count / maxBoxCount) * 20);
    setVal(r, 3, "▓".repeat(barLen) + "░".repeat(20-barLen));
    fc(r, 3, 1, 5, barColors[idx % barColors.length]); sz(r, 3, 1, 5, 10);
  });

  // ── Фінальний Footer ──────────────────────────────────────────
  const fRow = s5start + boxLoad.length + 3;
  merge(fRow, 1, 1, 8);
  setVal(fRow, 1, "🤖 Автоматично оновлюється щодня о 03:00 · 1333 Car Center · " + updated);
  bg(fRow, 1, 1, 8, "#050507"); fc(fRow, 1, 1, 8, "#444444"); sz(fRow, 1, 1, 8, 9);
  align(fRow, 1, 1, 8, "center"); sheet.setRowHeight(fRow, 24);

  // Фон усього полотна
  bg(1, 1, fRow, 8, "#050507");
  // Перемальовуємо локальні фони поверх (GAS застосовує порядково — це ОК)
  // (Вже зроблено вище)

  // ✅ v10: НАТИВНІ ГРАФІКИ (EmbeddedChart) — як на сайті
  try {
    buildAnalyticsCharts(sheet, charts, fRow + 2);
  } catch (chErr) {
    Logger.log("⚠️ Графіки не побудовані: " + chErr);
    logError("buildAnalyticsCharts", chErr, "crm");
  }

  Logger.log("✅ Аналітика оновлена: " + fRow + " рядків");
  return kpis.map(r => r[0] + ": " + r[1]);
}

// ✅ v10: побудова нативних графіків Google Sheets на листі "Аналітика".
// Дані для графіків записуються у службову область (колонки K+), яку ховаємо.
// Графіки розміщуються під основним дашбордом (з рядка startRow).
function buildAnalyticsCharts(sheet, charts, startRow) {
  // Використовуємо глобальний сервіс Charts (Charts.ChartType.*) — переобявляти не потрібно.
  const HELP_COL = 11; // колонка K — початок службової області даних
  let dataRow = 1;

  // допоміжна: записує двовимірний масив у службову область і повертає Range
  const putData = (rows) => {
    if (!rows.length) return null;
    const r0 = dataRow;
    const nCols = rows[0].length;
    sheet.getRange(r0, HELP_COL, rows.length, nCols).setValues(rows);
    dataRow += rows.length + 1; // порожній рядок-роздільник
    return sheet.getRange(r0, HELP_COL, rows.length, nCols);
  };

  const COLORS = ["#22c55e", "#a78bfa", "#f97316", "#eab308", "#3b82f6", "#ef4444", "#06b6d4"];
  let anchor = startRow;
  const CHART_ROWS = 18; // висота одного графіка в рядках

  // 1️⃣ Динаміка доходу (лінійний, 14 днів)
  const trend = charts.revenueTrend || [];
  if (trend.length) {
    const rows = [["Дата", "Послуги", "Абонементи", "Разом"]];
    trend.forEach(t => rows.push([t.label, Number(t.services) || 0, Number(t.subs) || 0, Number(t.total) || 0]));
    const rng = putData(rows);
    const chart = sheet.newChart()
      .setChartType(Charts.ChartType.LINE)
      .addRange(rng)
      .setNumHeaders(1)
      .setOption("title", "📈 Динаміка доходу · 14 днів")
      .setOption("legend", { position: "bottom", textStyle: { color: "#cccccc" } })
      .setOption("backgroundColor", "#0a0a10")
      .setOption("titleTextStyle", { color: "#ffffff", fontSize: 14 })
      .setOption("colors", [COLORS[4], COLORS[1], COLORS[0]])
      .setOption("hAxis", { textStyle: { color: "#aaaaaa" } })
      .setOption("vAxis", { textStyle: { color: "#aaaaaa" }, gridlines: { color: "#222222" } })
      .setOption("curveType", "function")
      .setOption("width", 900)
      .setOption("height", 320)
      .setPosition(anchor, 1, 0, 0)
      .build();
    sheet.insertChart(chart);
    anchor += CHART_ROWS;
  }

  // допоміжна для pie/column графіків {name,count}
  const buildCategoryChart = (items, type, title, headerLabel, colOffset) => {
    if (!items || !items.length) return;
    const rows = [[headerLabel, "Кількість"]];
    items.forEach(it => rows.push([String(it.name || "—"), Number(it.count) || 0]));
    const rng = putData(rows);
    let b = sheet.newChart()
      .setChartType(type)
      .addRange(rng)
      .setNumHeaders(1)
      .setOption("title", title)
      .setOption("legend", { position: type === Charts.ChartType.PIE ? "right" : "none", textStyle: { color: "#cccccc" } })
      .setOption("backgroundColor", "#0a0a10")
      .setOption("titleTextStyle", { color: "#ffffff", fontSize: 13 })
      .setOption("colors", COLORS)
      .setOption("hAxis", { textStyle: { color: "#aaaaaa" } })
      .setOption("vAxis", { textStyle: { color: "#aaaaaa" }, gridlines: { color: "#222222" } })
      .setOption("width", 450)
      .setOption("height", 300)
      .setPosition(anchor, 1 + colOffset, 0, 0)
      .build();
    sheet.insertChart(b);
  };

  // 2️⃣ Структура доходу (pie: послуги vs абонементи) та 3️⃣ Статуси записів (pie)
  const totalSvc = trend.reduce((s, t) => s + (Number(t.services) || 0), 0);
  const totalSub = trend.reduce((s, t) => s + (Number(t.subs) || 0), 0);
  buildCategoryChart(
    [{ name: "Послуги", count: totalSvc }, { name: "Абонементи", count: totalSub }],
    Charts.ChartType.PIE, "💰 Структура доходу", "Канал", 0
  );
  buildCategoryChart(charts.bookingStatuses, Charts.ChartType.PIE, "📋 Статуси записів (30 днів)", "Статус", 4);
  anchor += CHART_ROWS;

  // 4️⃣ Топ послуг (стовпчастий) та 5️⃣ Абонементи за типом (pie)
  buildCategoryChart(charts.topServices, Charts.ChartType.COLUMN, "🔧 Топ послуг", "Послуга", 0);
  buildCategoryChart(charts.subsByType, Charts.ChartType.PIE, "💎 Абонементи за типом", "Тип", 4);
  anchor += CHART_ROWS;

  // 6️⃣ Нові клієнти (стовпчастий) та 7️⃣ Завантаженість боксів (стовпчастий)
  buildCategoryChart(
    (charts.newClientsTrend || []).map(c => ({ name: c.label, count: c.count })),
    Charts.ChartType.COLUMN, "👥 Нові клієнти (14 днів)", "Дата", 0
  );
  buildCategoryChart(charts.boxLoad, Charts.ChartType.COLUMN, "🏠 Завантаженість боксів", "Бокс", 4);
  anchor += CHART_ROWS;

  // Ховаємо службову область з даними для графіків (колонки K..N)
  try { sheet.hideColumns(HELP_COL, 4); } catch (e) { /* ignore */ }
}

function sendVisitReminders() {
  const data = safeGetRangeValues(getSheet(SHEET_BOOKINGS), 2, 1, null, 12);
  if (!data || !data.length) return 0;
  let sent = 0;
  data.forEach(r => {
    if (!r || !r[0] || !r[5]) return;
    const status = String(r[9] || "");
    if (!(status.includes("Підтверджено") || status.includes("Очікує"))) return;
    const dt = asDate(r[1]);
    const hour = parseTimeString(r[3]);
    if (!dt || hour === null) return;
    dt.setHours(hour, 0, 0, 0);
    const diffHours = (dt.getTime() - new Date().getTime()) / 3600000;
    [[24, "24h"], [1, "1h"]].forEach(([target, label]) => {
      if (diffHours < target || diffHours > target + 1) return;
      const key = "reminder_visit_" + r[0] + "_" + label;
      if (scriptProperties.getProperty(key)) return;
      const client = findClientById(String(r[5]));
      if (client?.telegramId) {
        sendMessage(client.telegramId, "⏰ <b>Нагадування</b>\n📅 " + fmtDate(dt) + " " + normalizeTime(r[3]) + "\n🏠 " + r[4]);
        scriptProperties.setProperty(key, "1");
        sent++;
      }
    });
  });
  return sent;
}

function sendSubscriptionExpiryReminders() {
  const data = safeGetRangeValues(getSheet(SHEET_SUBS), 2, 1, null, 16);
  if (!data || !data.length) return 0;
  let sent = 0;
  data.forEach(r => {
    if (!r || !r[0] || !r[1] || !isActiveStatus(r[10])) return;
    const end = asDate(r[7]);
    if (!end) return;
    const today = new Date();
    const days = Math.ceil((new Date(end.getFullYear(), end.getMonth(), end.getDate()) - new Date(today.getFullYear(), today.getMonth(), today.getDate())) / 86400000);
    if ([7, 3, 1].indexOf(days) === -1) return;
    const key = "reminder_sub_" + r[1] + "_" + days;
    if (scriptProperties.getProperty(key)) return;
    const client = findClientById(String(r[0]));
    if (client?.telegramId) {
      sendMessage(client.telegramId, "💎 Абонемент закінчиться за " + days + " дн.");
      scriptProperties.setProperty(key, "1");
      sent++;
    }
  });
  return sent;
}

function broadcastTelegram(message, segment, actor) {
  if (!message) return { success: false, sent: 0, error: "message required" };
  const clients = safeGetRangeValues(getSheet(SHEET_CLIENTS), 2, 1, null, 13).filter(r => r && r[0] && r[3]);
  let sent = 0;
  clients.forEach(r => {
    const status = String(r[4] || CLIENT_STATUS_ACTIVE);
    if (isClientBlockedStatus(status)) return;
    if (sendMessage(String(r[3]).trim(), message)) sent++;
  });
  logAction(actor || "CRM", "Массовая рассылка", "Telegram", segment || "all", "", sent, "");
  return { success: true, sent };
}

