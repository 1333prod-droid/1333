function doGet(e) {
  const action = e.parameter.action || '';
  let result = {};
  const cache = CacheService.getScriptCache();
  try {
    // ✅ v9 SEC: ПРОВЕРКА АВТОРИЗАЦИИ ПЕРВОЙ
    if (action === 'verifyCrmPin') { return jsonResponse(verifyCrmPin(e.parameter.pin || "")); }
    if (action === 'sendClientAuthCode') { return jsonResponse(sendClientAuthCode(e.parameter.phone || "")); }
    if (action === 'verifyClientAuthCode') { return jsonResponse(verifyClientAuthCode(e.parameter.phone || "", e.parameter.code || "")); }
    if (action === 'getClientProfileData') { return jsonResponse(getClientProfileData(e.parameter.clientId || "", e.parameter.clientToken || "")); }

    // ✅ v9 NEW: Єдиний вхід — визначаємо хто це (клієнт чи адмін) за телефоном
    if (action === 'checkLoginPhone') { return jsonResponse(checkLoginPhone(e.parameter.phone || "")); }
    // ✅ v9 NEW: Верифікація коду адміна (окремо від клієнтського)
    if (action === 'verifyAdminSiteCode') { return jsonResponse(verifyAdminSiteCode(e.parameter.adminId || "", e.parameter.code || "")); }

    // ✅ v9 SEC: Перевірка адмін-токена ДО maintenance
    if (requiresAdminAuth(action) && !isValidAdminToken(e.parameter.adminToken || "")) {
      logAction("web", "Unauthorized API", "CRM", action, "", "", "Нет adminToken");
      return jsonResponse({ success: false, unauthorized: true, error: "Unauthorized" });
    }

    // ✅ v9.1 PERF: ensureSchema() і runDailyMaintenance() ВИНЕСЕНІ з doGet.
    // Обслуговування запускається раз на добу тригером setupDailyTrigger().

    // ────────────────────────────────────────────────────────────────
    // ✅ v9 PERF: getTimesAndBoxes with in-memory booking check
    if (action === 'getTimesAndBoxes') {
      const dateStr = e.parameter.date;
      const todayStr = Utilities.formatDate(new Date(), TZ, "dd.MM.yyyy");
      const isToday = (dateStr === todayStr);
