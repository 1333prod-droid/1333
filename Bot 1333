    // v9.3 FIX: колонка 3 (Час) → тільки HH:mm, інші → dd.MM.yyyy
    if (colIdx === 3) return Utilities.formatDate(c, TZ, "HH:mm");
    return Utilities.formatDate(c, TZ, "dd.MM.yyyy");
  }));

  try {
    const payload = JSON.stringify(filtered);
    if (payload.length < 95000) cache.put(key, payload, 600);
  } catch (e) {}
  return filtered;
}

function _isBoxBookedInMemory(bookingsForDate, timeStr, boxName) {
  const normInputTime = normalizeTime(timeStr);
  for (let i = 0; i < bookingsForDate.length; i++) {
    const r = bookingsForDate[i];
    let bTime = r[3] instanceof Date ? Utilities.formatDate(r[3], TZ, "HH:mm") : String(r[3]).trim();
    const bBox = String(r[4]).trim();
    const bStatus = String(r[9]).trim();
    if (bBox === boxName &&
        (bStatus.includes("Підтверджено") || bStatus.includes("Очікує") || bStatus.includes("роботі"))) {
      if (normalizeTime(bTime) === normInputTime) return true;
    }
  }
  return false;
}

function isBoxBooked(dateStr, timeStr, boxName) {
  const bookingsForDate = _loadBookingsForDate(dateStr);
  return _isBoxBookedInMemory(bookingsForDate, timeStr, boxName);
}

// ✅ fix(подвійна запис): свіжа перевірка зайнятості бокса ПРЯМО з листа (без кешу).
// Бокс вважається зайнятим, якщо на цю дату/час є будь-який запис НЕ в статусі "Скасовано".
// Викликати ТІЛЬКИ під локом (в saveBooking) — це остаточна гарантія від гонки.
function _isSlotTakenFresh(dateStr, timeStr, boxName, excludeBookingId) {
  const sheet = getSheet(SHEET_BOOKINGS);
  if (!sheet) return false;
  const data = safeGetRangeValues(sheet, 2, 1, null, 12);
  if (!data || !data.length) return false;
  const normInputTime = normalizeTime(timeStr);
  const normBox = String(boxName).trim();
  const skipId = excludeBookingId ? String(excludeBookingId).trim() : "";
  for (let i = 0; i < data.length; i++) {
    const r = data[i];
    if (!r || !r[0]) continue;
    if (skipId && String(r[0]).trim() === skipId) continue; // ✅ ігноруємо сам запис, який переносимо
    const bDate = r[1] instanceof Date ? Utilities.formatDate(r[1], TZ, "dd.MM.yyyy") : String(r[1]).trim();
    if (bDate !== String(dateStr).trim()) continue;
    const bTime = r[3] instanceof Date ? Utilities.formatDate(r[3], TZ, "HH:mm") : String(r[3]).trim();
    if (normalizeTime(bTime) !== normInputTime) continue;
    if (String(r[4]).trim() !== normBox) continue;
    const bStatus = String(r[9] || "").trim();
    if (bStatus.includes("Скасовано")) continue; // скасовані не займають бокс
    return true; // є активний запис на цей бокс/час
  }
  return false;
}

function getAvailableBoxes(dateStr, timeStr) {
  const bookingsForDate = _loadBookingsForDate(dateStr);
  return getBoxesForTime(dateStr, timeStr).filter(b => !_isBoxBookedInMemory(bookingsForDate, timeStr, b));
}

function isTimeFullyBooked(dateStr, timeStr) {
  const all = getBoxesForTime(dateStr, timeStr);
  if (!all.length) return true;
  const bookingsForDate = _loadBookingsForDate(dateStr);
  return all.every(b => _isBoxBookedInMemory(bookingsForDate, timeStr, b));
}

function getBoxReleaseText(dateStr, boxName) {
  const bookingsForDate = _loadBookingsForDate(dateStr);
  const now = new Date();
  const nowMinutes = Number(Utilities.formatDate(now, TZ, "H")) * 60 + Number(Utilities.formatDate(now, TZ, "m"));
  let best = null;
  bookingsForDate.forEach(r => {
    if (!r || !r[0]) return;
    const bBox = String(r[4]).trim();
    const status = String(r[9]).trim();
    if (bBox !== boxName || !(status.includes("роботі") || status.includes("Підтверджено") || status.includes("Очікує"))) return;
    const time = r[3] instanceof Date ? Utilities.formatDate(r[3], TZ, "HH:mm") : normalizeTime(r[3]);
    const h = parseTimeString(time);
    if (h === null) return;
    const releaseMinutes = (h + 1) * 60;
    if (releaseMinutes >= nowMinutes && (best === null || releaseMinutes < best)) best = releaseMinutes;
  });
  if (best === null) return "";
  const diff = best - nowMinutes;
  if (diff <= 0) return "звільняється зараз";
  return "через " + Math.floor(diff / 60) + " год " + String(diff % 60).padStart(2, "0") + " хв";
}

function getClientRow(clientId) {
  const data = safeGetRangeValues(getSheet(SHEET_CLIENTS), 2, 1, null, 13);
  if (!data || !data.length) return null;
  for (let i = 0; i < data.length; i++) {
    if (!data[i] || !data[i][0]) continue;
    if (String(data[i][0]).trim() === String(clientId).trim()) {
      return { row: i + 2, values: data[i] };
    }
  }
  return null;
}

function clientExists(clientId) { return !!getClientRow(clientId); }
function typeExists(typeId) { return getTypes().some(t => String(t.id).trim() === String(typeId).trim()); }

function subscriptionExists(subId, clientId) {
  const data = safeGetRangeValues(getSheet(SHEET_SUBS), 2, 1, null, 16);
  if (!data || !data.length) return false;
  return data.some(r => r && String(r[1]).trim() === String(subId).trim() &&
    (!clientId || String(r[0]).trim() === String(clientId).trim()));
}

function assertClientAllowed(clientId) {
  const found = getClientRow(clientId);
  if (!found) throw new Error("ClientID not found: " + clientId);
  const status = found.values[4] || CLIENT_STATUS_ACTIVE;
  if (isClientBlockedStatus(status)) throw new Error("Client is blocked/archived: " + clientId);
  return found;
}

function assertForeignKeys(keys) {
  if (keys.clientId) assertClientAllowed(keys.clientId);
  if (keys.typeId && !typeExists(keys.typeId)) throw new Error("TypeID not found: " + keys.typeId);
  if (keys.subId && !subscriptionExists(keys.subId, keys.clientId)) throw new Error("SubscriptionID not found: " + keys.subId);
}

function updateClientMetrics(clientId) {
  const client = getClientRow(clientId);
  if (!client) return false;
  const histData = safeGetRangeValues(getSheet(SHEET_HISTORY), 2, 1, null, 12);
  const subData = safeGetRangeValues(getSheet(SHEET_SUBS), 2, 1, null, 16);
  let visits = 0, visitTotal = 0, lastVisit = null, totalPurchases = 0;
  if (histData && histData.length) {
    histData.forEach(r => {
      if (!r || !r[0] || String(r[2]).trim() !== String(clientId).trim()) return;
      visits++;
      visitTotal += parseFloat(r[6]) || 0;
      const d = asDate(r[1]);
      if (d && (!lastVisit || d > lastVisit)) lastVisit = d;
    });
  }
  if (subData && subData.length) {
    subData.forEach(r => {
      if (!r || !r[0] || String(r[0]).trim() !== String(clientId).trim()) return;
      totalPurchases += parseFloat(r[5]) || 0;
    });
  }
  const averageCheck = visits ? visitTotal / visits : 0;
  const rowValues = client.values.slice(0, 13);
  rowValues[4] = rowValues[4] || CLIENT_STATUS_ACTIVE;
  rowValues[6] = getClientLiveBalance(clientId);
  rowValues[7] = visits;
  rowValues[8] = totalPurchases;
  rowValues[9] = fmt(averageCheck);
  rowValues[10] = lastVisit ? fmtDate(lastVisit) : "";
  getSheet(SHEET_CLIENTS).getRange(client.row, 1, 1, rowValues.length).setValues([rowValues]);
  return true;
}

// ✅ v9.2 AUDIT (п.7): батч-пересчёт метрик — листы читаются один раз, запись одним setValues().
function syncClientMetrics() {
  const clientSheet = getSheet(SHEET_CLIENTS);
  if (!clientSheet) return 0;
  const clients = safeGetRangeValues(clientSheet, 2, 1, null, 13);
  if (!clients || !clients.length) return 0;
  const histData = safeGetRangeValues(getSheet(SHEET_HISTORY), 2, 1, null, 12) || [];
  const subData  = safeGetRangeValues(getSheet(SHEET_SUBS), 2, 1, null, 16) || [];

  // агрегация по Клиенту за один проход по каждому листу
  const visitsMap = {}, visitTotalMap = {}, lastVisitMap = {}, purchasesMap = {}, balanceMap = {};
  histData.forEach(r => {
    if (!r || !r[0]) return;
    const cid = String(r[2]).trim();
    if (!cid) return;
    visitsMap[cid] = (visitsMap[cid] || 0) + 1;
    visitTotalMap[cid] = (visitTotalMap[cid] || 0) + (parseFloat(r[6]) || 0);
    const d = asDate(r[1]);
    if (d && (!lastVisitMap[cid] || d > lastVisitMap[cid])) lastVisitMap[cid] = d;
  });
  subData.forEach(r => {
    if (!r || !r[0]) return;
    const cid = String(r[0]).trim();
    purchasesMap[cid] = (purchasesMap[cid] || 0) + (parseFloat(r[5]) || 0);
    if (isActiveStatus(String(r[10]).trim())) balanceMap[cid] = (balanceMap[cid] || 0) + (parseFloat(r[9]) || 0);
  });

  let count = 0;
  const out = clients.map(r => {
    if (!r || !r[0]) return r.slice(0, 13);
    const cid = String(r[0]).trim();
    const visits = visitsMap[cid] || 0;
    const visitTotal = visitTotalMap[cid] || 0;
    const averageCheck = visits ? visitTotal / visits : 0;
    const rowValues = r.slice(0, 13);
    rowValues[4] = rowValues[4] || CLIENT_STATUS_ACTIVE;
    rowValues[6] = balanceMap[cid] || 0;
    rowValues[7] = visits;
    rowValues[8] = purchasesMap[cid] || 0;
    rowValues[9] = fmt(averageCheck);
    rowValues[10] = lastVisitMap[cid] ? fmtDate(lastVisitMap[cid]) : "";
    count++;
    return rowValues;
  });
  if (out.length) clientSheet.getRange(2, 1, out.length, 13).setValues(out);
  return count;
}

function expireSubscriptions() {
  return withScriptLock("expireSubscriptions", function() {
    const sheet = getSheet(SHEET_SUBS);
    const data = safeGetRangeValues(sheet, 2, 1, null, 16);
