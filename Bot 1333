function setWebhook() {
  requireConfig("BOT_TOKEN");
  requireConfig("WEBAPP_URL");
  const url = "https://api.telegram.org/bot" + BOT_TOKEN + "/setWebhook?url=" + WEBAPP_URL;
  try { UrlFetchApp.fetch(url); Logger.log("✅ Webhook set"); }
