            );
          } catch(e) { logError("confirmSubRequest notify", e, "CRM"); }
        }
      }
      result = { success: ok };
    }
  else if (action === 'getPublicCatalog') {
  result = getPublicCatalog();
}
    // ── Відхилити заявку (з CRM) ──────────────────────────────────
  else if (action === 'rejectSubRequest') {
      const reqToReject = getSubscriptionRequests().find(r => r.requestId === e.parameter.requestId);
      const ok = updateSubscriptionRequestStatus(e.parameter.requestId, '❌ Відхилена', "CRM", e.parameter.reason || "");
      if (ok && reqToReject) {
        let tgId = String(reqToReject.telegramId || "").trim();
        if (!tgId || tgId === 'undefined' || tgId === '0' || isNaN(Number(tgId))) {
          const cl = findClientById(reqToReject.clientId);
          if (cl && cl.telegramId && cl.telegramId !== '0') tgId = String(cl.telegramId);
        }
        if (tgId && !isNaN(Number(tgId))) {
          try {
            sendMessage(Number(tgId),
              "❌ <b>Заявку на абонемент відхилено</b>\n\n" +
              "💎 " + reqToReject.typeName + "\n" +
              (e.parameter.reason ? "💬 Причина: " + e.parameter.reason + "\n" : "") +
              "\nЗверніться до адміністратора: " + PHONE
            );
          } catch(e) { logError("rejectSubRequest notify", e, "CRM"); }
        }
      }
      result = { success: ok };
    }

    // ── Довільне оновлення статусу заявки ──────────────────────────
    else if (action === 'updateSubRequestStatus') {
      result = { success: updateSubscriptionRequestStatus(e.parameter.requestId, e.parameter.status, "CRM", e.parameter.reason || "") };
    }

    // ── Повний перерахунок балансів + метрик клієнтів ───────────────
    else if (action === 'recalcAllBalances') {
      const count = syncAllBalances();
      const metrics = syncClientMetrics();
      result = { success: true, updated: count, metrics };
    }

    // ── Масова розсилка у Telegram ───────────────────────────────
    else if (action === 'broadcastTelegram') {
      result = broadcastTelegram(e.parameter.message || "", e.parameter.segment || "all", "CRM");
    }

    // ── Баланс одного клієнта ──────────────────────────────────────
    else if (action === 'getClientBalance') {
      const cid = e.parameter.clientId;
      result = { clientId: cid, balance: getClientLiveBalance(cid) };
    }

  } catch (err) {
    logError(action || "doGet", err, e?.parameter?.adminToken ? "crm" : "web");
    result = { success: false, error: String(err) };
  }

  return jsonResponse(result);
}
