function sendClientAuthCode(phone) {
  if (!phone) return { success: false, error: "phone required" };
  const normPhone = normalizePhone(phone);
  const client = findClientByPhone(normPhone);
  if (!client) return { success: false, error: "client_not_found" };
  if (!client.telegramId || client.telegramId === "0" || client.telegramId === "") {
    return { success: false, error: "no_telegram", hint: "Прив'яжіть Telegram" };
  }
  const code = String(Math.floor(1000 + Math.random() * 9000));
  // ✅ v9.2 AUDIT (п.3): код в CacheService с TTL (истекает сам), а не в ScriptProperties
  CacheService.getScriptCache().put("auth_" + normPhone, code, Math.floor(AUTH_CODE_TTL_MS / 1000));
  sendCodeMessage(client.telegramId, "🔐 <b>Код входу</b>", code, "⏳ Дійсний 5 хвилин");
  logAction("web", "Запит коду", "Client", client.clientId, "", normPhone, "");
  return { success: true, hint: "Код надіслано" };
}

function verifyClientAuthCode(phone, code) {
  if (!phone || !code) return { success: false, error: "phone and code required" };
  const normPhone = normalizePhone(phone);
  // ✅ v9.2 AUDIT (п.3): код из CacheService; срок жизни контролирует сам кэш (TTL)
  const cache = CacheService.getScriptCache();
  const storedCode = cache.get("auth_" + normPhone);
  if (!storedCode) return { success: false, error: "code_expired" }; // нет в кэше = нет/истёк
  if (!secureCompare(String(code), storedCode)) {
    return { success: false, error: "code_invalid" };
  }
  cache.remove("auth_" + normPhone);
  const client = findClientByPhone(normPhone);
  if (!client) return { success: false, error: "client_not_found" };
  const clientToken = Utilities.getUuid();
  CacheService.getScriptCache().put("client_token_" + clientToken, client.clientId, CLIENT_TOKEN_TTL_SECONDS);
  logAction("web", "Вход в кабінет", "Client", client.clientId, "", "ok", normPhone);
  return { success: true, clientToken, clientId: client.clientId, expiresIn: CLIENT_TOKEN_TTL_SECONDS };
}

function isValidClientToken(clientToken, clientId) {
  if (!clientToken || !clientId) return false;
  const storedId = CacheService.getScriptCache().get("client_token_" + clientToken);
  return storedId === String(clientId);
}

function getClientProfileData(clientId, clientToken) {
  if (!isValidClientToken(clientToken, clientId)) {
    return { success: false, unauthorized: true, error: "Invalid token" };
  }
  const client = findClientById(clientId);
  if (!client) return { success: false, error: "client_not_found" };
  const subs = getClientSubs(clientId);
  const history = getClientHistory(clientId);
  const bookings = getClientBookings(clientId);
  return {
    success: true,
    profile: {
      clientId: client.clientId,
      name: client.name,
      phone: normalizePhone(String(client.phone || "")),
      status: client.status,
      registered: client.registered,
      balance: client.balance,
      visits: client.visits,
      lastVisit: client.lastVisit,
      totalPurchases: client.totalPurchases
    },
    subs: subs.map(s => ({
      subId: s.subId,
      typeName: s.typeName,
      balance: s.balance,
      spent: s.spent,
      startDate: s.startDate,
      endDate: s.endDate,
      status: s.status,
      amount: s.amount
    })),
    history: history.slice(-20).reverse(),
    bookings: bookings.filter(b => !String(b.status).includes("Скасовано")).slice(-10).reverse()
  };
}

// ✅ v9 NEW: визначає роль за номером телефону
// roles: "client" | "admin" | "not_found"
function checkLoginPhone(phone) {
  if (!phone) return { success: false, error: "phone required" };
  const normPhone = normalizePhone(phone);
  // Перевірка: чи це телефон адміна з налаштувань
  const adminPhone = scriptProperties.getProperty("ADMIN_PHONE") || "";
  if (adminPhone && normalizePhone(adminPhone) === normPhone) {
    // Надсилаємо код адміну в Telegram
    const code = String(Math.floor(1000 + Math.random() * 9000));
    // ✅ v9.2 AUDIT (п.3): код админа в CacheService с TTL
    CacheService.getScriptCache().put("admin_site_code_" + ADMIN_ID, code, Math.floor(AUTH_CODE_TTL_MS / 1000));
    sendCodeMessage(ADMIN_ID, "🔑 <b>Код для входу на сайт</b>", code, "⏳ Дійсний 5 хвилин. Нікому не передавайте!");
    return { success: true, role: "admin", hint: "Код надіслано у Telegram" };
  }
  // Перевірка: чи є клієнт з таким телефоном
  const client = findClientByPhone(normPhone);
  if (!client) return { success: false, role: "not_found", error: "Номер не знайдено" };
  if (!client.telegramId || client.telegramId === "0" || client.telegramId === "") {
    return { success: false, role: "no_telegram", error: "Telegram не прив'язано" };
  }
  // Надсилаємо код клієнту
  const code = String(Math.floor(1000 + Math.random() * 9000));
  // ✅ v9.2 AUDIT (п.3): код клиента в CacheService с TTL
  CacheService.getScriptCache().put("auth_" + normPhone, code, Math.floor(AUTH_CODE_TTL_MS / 1000));
  sendCodeMessage(client.telegramId, "🔐 <b>Ваш код для входу в Особистий кабінет</b>", code, "⏳ Дійсний 5 хвилин");
  logAction("web", "Запит коду входу", "Client", client.clientId, "", normPhone, "");
  return { success: true, role: "client", hint: "Код надіслано у Telegram" };
}

// ✅ v9 NEW: верифікація коду адміна (з сайту)
function verifyAdminSiteCode(adminIdStr, code) {
  if (!code) return { success: false, error: "code required" };
  const adminId = adminIdStr || String(ADMIN_ID);
  // ✅ v9.2 AUDIT (п.3): код из CacheService; TTL контролирует срок
  const cache = CacheService.getScriptCache();
  const storedCode = cache.get("admin_site_code_" + adminId);
  if (!storedCode) return { success: false, error: "code_expired" };
  if (!secureCompare(String(code), storedCode)) return { success: false, error: "code_invalid" };
  cache.remove("admin_site_code_" + adminId);
  // Видаємо CRM-токен адміна через існуючий механізм
  const token = createAdminSession();
  logAction("web", "Вхід адміна через сайт", "Admin", adminId, "", "ok", "site_code");
  return { success: true, role: "admin", token, expiresIn: CRM_SESSION_TTL_SECONDS };
}

// ─────────────────────── STATE ─────────────────────────────────

function getState(userId) {
  try { const s = scriptProperties.getProperty('user_' + userId); return s ? JSON.parse(s) : null; }
  catch(e) { return null; }
}

function setState(userId, state) {
  try { scriptProperties.setProperty('user_' + userId, JSON.stringify(state)); } catch(e) {}
}

function deleteState(userId) { scriptProperties.deleteProperty('user_' + userId); }

