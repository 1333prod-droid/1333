// ✅ v9.1: логи буферизуються у ScriptProperties під локом і скидаються пачкою.
const AUDIT_QUEUE_KEY = "AUDIT_QUEUE";
const AUDIT_FLUSH_THRESHOLD = 15;
const AUDIT_CRITICAL_OPS = ["Списание", "Продажа абонемента", "Заморозка абонемента",
  "Розморозка абонемента", "Автозакрытие абонемента"];

function logAction(user, operation, entity, entityId, beforeValue, afterValue, comment) {
  try {
    const safeStr = (v) => {
      if (v === undefined || v === null) return "";
      const s = String(v);
      return (s.startsWith("=") || s.startsWith("+") || s.startsWith("-") || s.startsWith("@"))
        ? "'" + s : s;
    };
    const row = [
      Utilities.formatDate(new Date(), TZ, "dd.MM.yyyy HH:mm:ss"),
      safeStr(user), safeStr(operation), safeStr(entity), safeStr(entityId),
      safeStr(beforeValue), safeStr(afterValue), safeStr(comment)
    ];
    const isCritical = AUDIT_CRITICAL_OPS.some(op =>
      String(operation || "").toLowerCase().includes(op.toLowerCase()));

    // короткий лок ТІЛЬКИ на запис черги, щоб не втрачати логи при гонці запитів
    const lock = LockService.getScriptLock();
    let shouldFlush = false;
    try {
      lock.waitLock(5000);
      let queue = [];
      try { queue = JSON.parse(scriptProperties.getProperty(AUDIT_QUEUE_KEY) || "[]"); } catch (e) { queue = []; }
      queue.push(row);
      scriptProperties.setProperty(AUDIT_QUEUE_KEY, JSON.stringify(queue));
      shouldFlush = (queue.length >= AUDIT_FLUSH_THRESHOLD || isCritical);
    } finally {
      try { lock.releaseLock(); } catch (e) {}
    }
    if (shouldFlush) flushAuditQueue();
  } catch (e) { logError("logAction", e, user); }
}

// ✅ v9.1: пакетний скид черги логів одним setValues()
function flushAuditQueue() {
  const lock = LockService.getScriptLock();
  try {
    lock.waitLock(10000);
    let queue = [];
    try { queue = JSON.parse(scriptProperties.getProperty(AUDIT_QUEUE_KEY) || "[]"); } catch (e) { queue = []; }
    if (!queue.length) return 0;
    scriptProperties.deleteProperty(AUDIT_QUEUE_KEY);
    const sheet = getOrCreateSheet(SHEET_AUDIT_LOG);
    const startRow = sheet.getLastRow() + 1;
    sheet.getRange(startRow, 1, queue.length, 8).setValues(queue);
    return queue.length;
  } catch (e) {
    logError("flushAuditQueue", e, "system");
    return 0;
  } finally {
    try { lock.releaseLock(); } catch (e) {}
  }
}

// ✅ v10 PERF: лок використовується ВИКЛЮЧНО для транзакційних (write) операцій:
//   saveBooking / cancelBooking / rescheduleBooking / sellSubscription / updateBookingStatus тощо.
//   Аналітичні (read) операції — getAllBookings/getAllClients/getAnalyticsFull/getPublicCatalog —
//   НЕ беруть лок взагалі, тому читання ніколи не чекає на запис.
//   Час очікування зменшено 30s → 10s: швидкий fail замість довгого зависання під навантаженням.
//   Важливо: мережеві виклики (sendMessage у Telegram) винесені ЗА межі локу — лок тримається мінімально.
const WRITE_LOCK_WAIT_MS = 10000;
function withScriptLock(functionName, fn, user) {
  const lock = LockService.getScriptLock();
  try {
    lock.waitLock(WRITE_LOCK_WAIT_MS);
    return fn();
  } catch (e) {
    logError(functionName, e, user);
    throw e;
  } finally {
    try { lock.releaseLock(); } catch (releaseErr) {}
  }
}

function fmtDate(d) {
  if (!d) return "";
  if (typeof d === 'string') return d;
  if (d instanceof Date) return Utilities.formatDate(d, TZ, "dd.MM.yyyy");
  return "";
}

function parseDate(value) {
  if (!value) return "";
  if (typeof value === 'string') return value;
  if (value instanceof Date) return Utilities.formatDate(value, TZ, "dd.MM.yyyy");
  if (typeof value === 'number') {
    try {
      const ms = (Math.floor(value) - 25569) * 86400 * 1000;
      const dt = new Date(ms);
      if (dt.getFullYear() > 1900 && dt.getFullYear() < 2100)
        return Utilities.formatDate(dt, TZ, "dd.MM.yyyy");
    } catch(e) {}
  }
  return "";
}

function fmt(num) { return Math.round(num * 100) / 100; }

function normalizePhone(phone) {
  if (!phone) return "";
  let digits = String(phone).replace(/\D/g, "");
  if (digits.startsWith("380") && digits.length === 12) {} 
  else if (digits.startsWith("0") && digits.length === 10) digits = "38" + digits;
  else if (digits.length === 9) digits = "380" + digits;
  else if (digits.startsWith("38") && digits.length === 11) digits = "3" + digits;
  if (digits.length === 12 && digits.startsWith("38")) {
    return `+38(${digits.slice(2,5)})${digits.slice(5,8)} ${digits.slice(8,10)} ${digits.slice(10,12)}`;
  }
  return phone.startsWith("+") ? phone : "+" + digits;
}

function sha256Hex(value) {
  return Utilities.computeDigest(Utilities.DigestAlgorithm.SHA_256, String(value), Utilities.Charset.UTF_8)
    .map(b => (b < 0 ? b + 256 : b).toString(16).padStart(2, "0")).join("");
}

function secureCompare(a, b) {
  a = String(a || ""); b = String(b || "");
  if (a.length !== b.length) return false;
  let diff = 0;
  for (let i = 0; i < a.length; i++) diff |= a.charCodeAt(i) ^ b.charCodeAt(i);
  return diff === 0;
}

function isCrmPinValid(pin) {
  const hash = scriptProperties.getProperty("CRM_PIN_HASH");
  if (hash) return secureCompare(sha256Hex(pin), String(hash).toLowerCase());
  const plain = scriptProperties.getProperty("CRM_PIN");
  return !!plain && secureCompare(String(pin), String(plain));
}

