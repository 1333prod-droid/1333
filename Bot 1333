// ✅ v9.2 AUDIT (п.5): счётчики ID в ScriptProperties вместо сканирования всего листа.
// При первом вызове счётчик инициализируется максимумом из листа (fallback), что исключает коллизии.
function _scanMaxId(sheet, col, regex) {
  const data = safeGetRangeValues(sheet, 2, col, null, 1);
  let max = 0;
  if (data && data.length) data.forEach(r => { if (r && r[0]) { const m = String(r[0]).match(regex); if (m) max = Math.max(max, +m[1]); }});
  return max;
}

function _nextSeq(counterKey, sheet, col, regex) {
  let stored = scriptProperties.getProperty(counterKey);
  let current;
  if (stored === null || stored === undefined || stored === "") {
    current = _scanMaxId(sheet, col, regex); // инициализация по листу
  } else {
    current = parseInt(stored, 10) || _scanMaxId(sheet, col, regex);
  }
  const next = current + 1;
  scriptProperties.setProperty(counterKey, String(next));
  return next;
}

function genClientId() {
  const n = _nextSeq("LAST_NUM_CLIENT", getSheet(SHEET_CLIENTS), 1, /C-(\d+)/);
  return "C-" + String(n).padStart(3, "0");
}

function genBookingId() {
  const n = _nextSeq("LAST_NUM_BOOKING", getSheet(SHEET_BOOKINGS), 1, /B-(\d+)/);
